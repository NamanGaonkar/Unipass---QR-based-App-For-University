{
  "name": "unipass-backend",
  "version": "1.0.0",
  "description": "Backend API for UniPass authentication system",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "start:local": "node server.js",
    "db:status": "node -e \"const fs=require('fs');const p='./data/local-db.json';const d=JSON.parse(fs.readFileSync(p,'utf8'));console.log({subjects:(d.subjects||[]).length,attendance:(d.attendance||[]).length,file:p});\"",
    "db:backup": "node -e \"const fs=require('fs');const path=require('path');const src='./data/local-db.json';const dir='./data/backups';if(!fs.existsSync(dir))fs.mkdirSync(dir,{recursive:true});const dst=path.join(dir,`local-db-${Date.now()}.json`);fs.copyFileSync(src,dst);console.log('backup:',dst);\""
  },
  "keywords": ["authentication", "fido2", "totp", "express"],
  "author": "UniPass Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "otplib": "^12.0.1",
    "dotenv": "^16.3.1",
    "winston": "^3.11.0",
    "express-rate-limit": "^7.1.5",
    "crypto": "^1.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0"
  }
}
